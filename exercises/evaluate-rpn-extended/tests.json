{
  "functionName": "evaluateRPNExtended",
  "testCases": [
    { "input": [["2", "3", "^"]], "expected": 8 },
    { "input": [["5", "neg"]], "expected": -5 },
    { "input": [["2", "3", "^", "1", "-"]], "expected": 7 },
    { "input": [["3", "neg", "4", "+"]], "expected": 1 },
    { "input": [["2", "10", "^"]], "expected": 1024 },
    { "input": [["4", "neg", "neg"]], "expected": 4 },
    { "input": [["2", "3", "+", "2", "^"]], "expected": 25 },
    { "input": [["3", "2", "^", "4", "2", "^", "+"]], "expected": 25 },
    { "input": [["5", "1", "2", "+", "4", "*", "+", "3", "-"]], "expected": 14 },
    { "input": [["10", "3", "/", "neg"]], "expected": -3 }
  ]
}
